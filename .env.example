# ── 翻訳 ──────────────────────────────────────────────────────────────
# 翻訳バックエンド: google のみ（Claude翻訳は使用しない）
TRANSLATION_BACKEND=google

# ── Claude API（口語化・整形のみに使用） ────────────────────────────
# https://console.anthropic.com でAPIキーを取得
# 未設定の場合は整形スキップ（Google翻訳のまま）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Whisper ────────────────────────────────────────────────────────────
# tiny / base / small / medium / large-v3
WHISPER_MODEL=large-v3

# ── WhisperX / 話者識別 ─────────────────────────────────────────────────
# device: NVIDIA GPU搭載機（MSI Katana等）なら cuda、無い場合は cpu
WHISPERX_DEVICE=cuda
# compute_type: cuda=float16, cpu=int8 が標準（未設定ならdeviceに応じて自動選択）
# WHISPERX_COMPUTE_TYPE=float16
WHISPERX_BATCH_SIZE=16

# 話者分離(pyannote.audio)に必須。以下の手順でトークンを取得:
#   1. https://huggingface.co/settings/tokens でRead権限のトークンを発行
#   2. https://huggingface.co/pyannote/speaker-diarization-3.1 の利用規約に同意
#   3. https://huggingface.co/pyannote/segmentation-3.0 の利用規約にも同意
# 未設定の場合は話者識別をスキップし、全セグメントが単一話者(SPEAKER_00)として扱われる
# （＝話者別音声切り替えなしの従来動作にフォールバック）
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 話者数が事前に分かっている場合のヒント（任意・空なら自動推定）
DIARIZATION_MIN_SPEAKERS=
DIARIZATION_MAX_SPEAKERS=

# ── VOICEVOX ───────────────────────────────────────────────────────────
# VOICEVOXエンジンのURL（start_voicevox.sh で起動）
VOICEVOX_URL=http://localhost:50021
# 話速（1.0=標準、1.1=少し速め）
VOICEVOX_SPEED=1.1

# ── 声優スピーカーID ───────────────────────────────────────────────────
# VOICEVOX起動後 http://localhost:50021/speakers で全一覧確認可
# female: 3=ずんだもん, 8=春日部つむぎ, 9=雨晴はう
# male:   11=玄野武宏, 12=白上虎太郎
VOICEVOX_SPEAKER_FEMALE=3
VOICEVOX_SPEAKER_MALE=11

# ── サーバー ───────────────────────────────────────────────────────────
PORT=8000
